# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/unilink
# Or for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/unilink

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production

# Email Configuration (for OTP via Email)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# SMS Configuration (Optional - for OTP via SMS using Twilio)
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development
